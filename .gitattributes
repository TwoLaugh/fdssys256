# Normalise line endings so Windows checkouts (core.autocrlf=true) don't break the
# Linux build container. The e2e/docker-compose app image runs `./mvnw` inside
# eclipse-temurin; if mvnw is checked out CRLF, /bin/sh treats the trailing \r as part
# of each command and the image build dies with "exit code: 127". Keep the wrapper and
# all shell scripts LF; keep Windows batch wrappers CRLF.
mvnw text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
