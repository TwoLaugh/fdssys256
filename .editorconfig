# EditorConfig — https://editorconfig.org
# Standardised line endings, encoding, and indentation across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{java}]
indent_size = 4

[*.{yml,yaml,json,md}]
indent_size = 2

[*.{xml,properties}]
indent_size = 4

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
